<component type="desktop-application">
  <id>io.github.reakjra.omikuji</id>
  <url type="homepage">https://github.com/reakjra/omikuji</url>
  <url type="bugtracker">https://github.com/reakjra/omikuji/issues</url>
  <url type="vcs-browser">https://github.com/reakjra/omikuji</url>
  <developer_name>reakjra</developer_name>
  <name>Omikuji</name>
  <summary>Qt/QML based game launcher for Linux</summary>
  <icon type="stock">io.github.reakjra.omikuji</icon>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <content_rating type="oars-1.1"/>
  <categories>
    <category>Game</category>
    <category>PackageManager</category>
  </categories>
  <description>
    <p>
      A Qt/QML based games/apps launcher for Linux. Built 'cause I couldn't bear having 3 different launchers for just games.
    </p>
  </description>
  <releases>
    <release version="0.4.2" date="2026-06-23">
      <description>
        <ul>
          <li>"Open with Omikuji" picker for .exe files.</li>
          <li>Theme falls back to its own palette when the system color scheme is unknown.</li>
          <li>RPM packaging CI.</li>
        </ul>
      </description>
    </release>
    <release version="0.4.1" date="2026-06-22">
      <description>
        <p>Minor UI fixes.</p>
      </description>
    </release>
    <release version="0.4.0" date="2026-06-22">
      <description>
        <ul>
          <li>Added a System Info section in About with a one-click copyable hardware/OS dump for bug reports.</li>
          <li>The per-game GPU selector is now op.</li>
          <li>Reworked the Components settings tab and version manager onto the new UI.</li>
        </ul>
      </description>
    </release>
    <release version="0.3.0" date="2026-06-21">
      <description>
        <p>Major UI overhaul.</p>
      </description>
    </release>
    <release version="0.2.3" date="2026-06-17">
      <description>
        <ul>
          <li>Now games symlink on run their icon in ~/.local/share/icons/hicolor/256x256/apps/</li>
          <li>Added a create steam shortcut button.</li>
          <li>Fixed cli target resolution.</li>
          <li>Flatpak build now doesn't hide various options from permissions lock, just warn about it.</li>
          <li>Discord's RPC now shows the game name as the activity title.</li>
        </ul>
      </description>
    </release>
    <release version="0.2.2" date="2026-06-05">
      <description>
        <ul>
          <li>HoYoverse updates no longer fail when a patch's source file is missing (e.g. game-managed cutscenes); the file is skipped instead.</li>
          <li>Added a Repair action (right-click) for HoYoverse games to refetch missing or incomplete files.</li>
          <li>Parallelized the update patch phase for noticeably faster updates.</li>
        </ul>
      </description>
    </release>
    <release version="0.2.1" date="2026-05-17">
      <description>
        <ul>
          <li>Version metadata sync across Cargo and About tab.</li>
        </ul>
      </description>
    </release>
    <release version="0.2.0" date="2026-05-17">
      <description>
        <ul>
          <li>AppImage and Flatpak release pipelines.</li>
          <li>Discord Rich Presence integration.</li>
          <li>System tray icon.</li>
          <li>Font family picker and per-token theme color customization.</li>
          <li>Epic and GOG update detection with manual and automatic checks.</li>
          <li>HoYo downloads with Sophon (fixes Genshin stuck at 5.5.0 and other various problems).</li>
          <li>Gacha import flow with on-disk version detection across all supported titles.</li>
          <li>PGR now uses the new proper CDN.</li>
          <li>Runner picker grouped by Proton and Wine families.</li>
          <li>Double-click to launch games (toggleable).</li>
          <li>Default prefix path option in global defaults.</li>
        </ul>
      </description>
    </release>
  </releases>
  <launchable type="desktop-id">io.github.reakjra.omikuji</launchable>
  <branding>
    <color type="primary" scheme_preference="light">#e1cc4c</color>
